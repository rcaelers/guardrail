##
## Builder
##

FROM --platform=$BUILDPLATFORM rustlang/rust:nightly-alpine AS builder

ENV RUSTUP_PERMIT_COPY_RENAME=true

RUN apk add --no-cache \
    clang \
    openssl \
    pkgconfig \
    openssl-dev \
    openssl-libs-static \
    musl-dev \
    build-base \
    nodejs \
    npm

RUN mkdir -p /app
WORKDIR /app
COPY . .

RUN npm install
RUN npm run web:islands:build
RUN cargo build --release -p web

#
# Runtime
#

FROM alpine:latest

RUN addgroup -g 1000 -S guardrail && adduser -u 1000 -S guardrail -G guardrail

WORKDIR /app

RUN apk add --no-cache openssl ca-certificates tzdata tini && \
    rm -rf /var/cache/apk/*

COPY --from=builder /app/target/release/web /app/
COPY --from=builder /app/src/web/server/static /app/static

RUN mkdir -p /app/config && \
    chown -R guardrail:guardrail /app

VOLUME ["/app/config"]

USER guardrail

ENTRYPOINT ["/sbin/tini", "--"]

CMD ["/app/web", "-C", "/app/config"]
