# Example environment variables for development

# DATABASE_URL=

# Enable debug logging for your crates, info for everything else
RUST_LOG=jobs=debug,repos=debug,common=debug,data=debug,info

# Alternative: Debug only for maintenance modules
# RUST_LOG=jobs::maintenance=debug,info

# Alternative: Very verbose for troubleshooting
# RUST_LOG=jobs=trace,repos=trace,debug
